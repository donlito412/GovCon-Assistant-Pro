# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (AI Assistant)
ANTHROPIC_API_KEY=your_anthropic_api_key

# SAM.gov
SAMGOV_API_KEY=your_samgov_api_key

# Google Places (company search)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Brave Search (company search fallback)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Resend (email alerts + outreach)
RESEND_API_KEY=your_resend_api_key

# Eventbrite (events)
EVENTBRITE_API_KEY=your_eventbrite_api_key

# Security secrets (generate with: openssl rand -hex 32)
INGEST_SECRET=your_ingest_secret
CRON_SECRET=your_cron_secret

# App config
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
ALERT_FROM_EMAIL=noreply@yourdomain.com
ALERT_TO_EMAIL=your@email.com
RESEND_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_SENDER_NAME=Jon Murphree
NEXT_PUBLIC_SENDER_COMPANY=Murphree Enterprises
