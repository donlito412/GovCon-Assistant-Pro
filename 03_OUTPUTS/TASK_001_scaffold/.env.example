# ============================================================
# GOVCON ASSISTANT PRO — ENVIRONMENT VARIABLES
# Copy this to .env.local for local development
# Set all values in Netlify UI → Site Settings → Environment Variables
# NEVER commit .env.local to GitHub
# ============================================================

# ------------------------------------------------------------
# SUPABASE (required — all tasks)
# Find at: supabase.com → your project → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# SAM.GOV API KEY (required — TASK_002, TASK_014, TASK_018)
# Find at: sam.gov → your profile → Public API Key
# Used for: contract opportunities, entity search, forecasts
# ------------------------------------------------------------
SAMGOV_API_KEY=your_samgov_api_key

# ------------------------------------------------------------
# ANTHROPIC API KEY (required — TASK_017 AI Assistant)
# Find at: console.anthropic.com → API Keys
# Key name on your account: GovCon
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# ------------------------------------------------------------
# RESEND API KEY (required — TASK_006 alerts, TASK_015 outreach)
# Find at: resend.com → API Keys
# Free tier: 3,000 emails/month
# ------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

# ------------------------------------------------------------
# EVENTBRITE API KEY (required — TASK_013 events)
# Find at: eventbrite.com/platform → My Apps → your app
# ------------------------------------------------------------
EVENTBRITE_API_KEY=your_eventbrite_api_key

# ------------------------------------------------------------
# INGEST SECRET (required — protects ingestion endpoints)
# Generate: openssl rand -hex 32
# Used in: Authorization header on all /api/ingest/* routes
# ------------------------------------------------------------
INGEST_SECRET=your_random_32_char_secret

# ------------------------------------------------------------
# APP URL (required — used in email links, cron callbacks)
# Local: http://localhost:3000
# Production: https://your-site-name.netlify.app (or custom domain)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# EMAIL SENDER (required — Resend from address)
# Must be a verified domain in your Resend account
# ------------------------------------------------------------
RESEND_FROM_EMAIL=alerts@yourdomain.com
